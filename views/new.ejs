<section class="animate-fade-in" style="max-width: 800px; margin: 0 auto;">
  <div class="editor-header">
    <span class="label-stamp" style="display: block; margin-bottom: 12px;">New Module</span>
    <h1>Create New Post</h1>
    <p>Share your thoughts with precision.</p>
  </div>

  <form action="/posts" method="POST" class="editor-panel">
    <!-- Vent slots -->
    <div style="position: absolute; top: 18px; right: 24px; display: flex; gap: 3px;">
      <div style="width: 2px; height: 20px; border-radius: 9999px; background: var(--muted); box-shadow: inset 1px 1px 2px rgba(0,0,0,0.1);"></div>
      <div style="width: 2px; height: 20px; border-radius: 9999px; background: var(--muted); box-shadow: inset 1px 1px 2px rgba(0,0,0,0.1);"></div>
      <div style="width: 2px; height: 20px; border-radius: 9999px; background: var(--muted); box-shadow: inset 1px 1px 2px rgba(0,0,0,0.1);"></div>
    </div>

    <div class="form-group">
      <label for="title">Post Title</label>
      <input id="title" name="title" type="text" placeholder="Enter an engaging title..." autofocus />
    </div>

    <div class="form-group">
      <label for="content">Content</label>
      <input type="hidden" name="content" id="content">
      <div id="editor-container" class="editor-well"></div>
    </div>

    <div class="editor-actions">
      <a href="/my-posts" class="btn btn-secondary">Cancel</a>
      <button type="submit" class="btn btn-primary" style="padding: 14px 36px;">Publish Post</button>
    </div>
  </form>
</section>
