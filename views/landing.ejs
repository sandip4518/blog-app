<!-- HERO SECTION -->
<div class="hero-section">
  <div class="animate-fade-in" style="margin-bottom: 20px;">
    <span class="label-stamp" style="display: inline-flex; align-items: center; gap: 8px;">
      <span class="led led-green"></span>
      System Online — Ready to Write
    </span>
  </div>
  
  <h1 class="animate-fade-in delay-1">
    Forge Your Story<br>
    <span class="hero-accent">With Precision</span>
  </h1>
  
  <p class="hero-subtitle animate-fade-in delay-2">
    A precision-engineered space for your thoughts. Create, manage, and share your ideas with a distraction-free, mechanically-solid writing experience.
  </p>
  
  <div class="hero-cta-group animate-fade-in delay-3">
    <% if (locals.user) { %>
      <a href="/my-posts" class="btn btn-primary" style="padding: 16px 36px; font-size: 0.95rem;">
        Go to Dashboard
      </a>
      <a href="/posts/new" class="btn btn-secondary" style="padding: 16px 36px; font-size: 0.95rem;">
        Start Writing
      </a>
    <% } else { %>
      <a href="/register" class="btn btn-primary" style="padding: 16px 36px; font-size: 0.95rem;">
        Start Your Journey
      </a>
      <a href="/login" class="btn btn-secondary" style="padding: 16px 36px; font-size: 0.95rem;">
        Sign In
      </a>
    <% } %>
  </div>

  <!-- Device Mockup -->
  <div class="hero-device animate-fade-in delay-4">
    <div class="hero-device-screen">
      <div class="screen-content">
        <div style="grid-column: 1 / -1; display: flex; flex-direction: column; gap: 8px; padding-top: 6px;">
          <div style="display: flex; gap: 6px; margin-bottom: 4px;">
            <div style="width: 8px; height: 8px; border-radius: 50%; background: #ff4757;"></div>
            <div style="width: 8px; height: 8px; border-radius: 50%; background: #f59e0b;"></div>
            <div style="width: 8px; height: 8px; border-radius: 50%; background: #22c55e;"></div>
          </div>
          <div class="screen-bar" style="width: 70%;"></div>
          <div class="screen-bar" style="width: 100%; opacity: 0.3; animation-delay: 0.5s;"></div>
          <div class="screen-bar" style="width: 45%; animation-delay: 1s;"></div>
        </div>
        <div class="screen-block" style="min-height: 60px;"></div>
        <div class="screen-block" style="min-height: 60px;"></div>
        <div class="screen-block" style="grid-column: 1 / -1; min-height: 40px;"></div>
      </div>
    </div>
    <div class="device-led"></div>
  </div>
</div>

<!-- FEATURES SECTION -->
<div class="animate-fade-in delay-3" style="margin-top: 80px; margin-bottom: 80px;">
  <div style="text-align: center; margin-bottom: 48px;">
    <span class="label-stamp">Specifications</span>
    <h2 style="margin-top: 12px; font-size: 2.5rem;">Built to Last</h2>
    <p style="max-width: 500px; margin: 0 auto;">Precision-engineered features for the modern writer.</p>
  </div>
  
  <div class="grid-posts" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px;">
    <div class="feature-card">
      <div class="feature-icon">✍️</div>
      <h3>Rich Text Editor</h3>
      <p>Express yourself fully with our powerful editor. Format text, add images, and structure your content exactly how you want.</p>
    </div>
    
    <div class="feature-card">
      <div class="feature-icon">🔒</div>
      <h3>Secure & Private</h3>
      <p>Your personal space is fortified. Industrial-grade security ensures your content and data remain strictly yours.</p>
    </div>
    
    <div class="feature-card">
      <div class="feature-icon">⚡</div>
      <h3>Blazing Fast</h3>
      <p>Built for peak performance. Experience instant page loads and smooth transitions as you navigate your stories.</p>
    </div>
  </div>
</div>

<!-- STATS BAR — Dark Technical Panel -->
<div class="animate-fade-in delay-4" style="background: #2d3436; border-radius: var(--radius-xl); padding: 40px; margin-bottom: 60px; box-shadow: var(--shadow-floating);">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 24px; text-align: center;">
    <div>
      <div style="font-family: var(--font-mono); font-size: 2.5rem; font-weight: 800; color: #ffffff; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));">99.9%</div>
      <div style="font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: #a8b2d1; margin-top: 4px;">Uptime</div>
    </div>
    <div>
      <div style="font-family: var(--font-mono); font-size: 2.5rem; font-weight: 800; color: #ffffff; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));">&lt;50ms</div>
      <div style="font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: #a8b2d1; margin-top: 4px;">Response</div>
    </div>
    <div>
      <div style="font-family: var(--font-mono); font-size: 2.5rem; font-weight: 800; color: #ffffff; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));">256-bit</div>
      <div style="font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: #a8b2d1; margin-top: 4px;">Encryption</div>
    </div>
    <div>
      <div style="font-family: var(--font-mono); font-size: 2.5rem; font-weight: 800; color: var(--accent); filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));">∞</div>
      <div style="font-family: var(--font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: #a8b2d1; margin-top: 4px;">Posts</div>
    </div>
  </div>
</div>
