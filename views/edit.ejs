<section class="animate-fade-in" style="max-width: 800px; margin: 0 auto;">
  <div class="editor-header">
    <span class="label-stamp" style="display: block; margin-bottom: 12px;">Edit Module</span>
    <h1>Edit Post</h1>
    <p>Refine and recalibrate your content.</p>
  </div>

  <form action="/posts/<%= post.id %>?_method=PUT" method="POST" class="editor-panel" style="position: relative;">
    <!-- Vent slots -->
    <div style="position: absolute; top: 18px; right: 24px; display: flex; gap: 3px;">
      <div style="width: 2px; height: 20px; border-radius: 9999px; background: var(--muted); box-shadow: inset 1px 1px 2px rgba(0,0,0,0.1);"></div>
      <div style="width: 2px; height: 20px; border-radius: 9999px; background: var(--muted); box-shadow: inset 1px 1px 2px rgba(0,0,0,0.1);"></div>
      <div style="width: 2px; height: 20px; border-radius: 9999px; background: var(--muted); box-shadow: inset 1px 1px 2px rgba(0,0,0,0.1);"></div>
    </div>

    <div class="form-group">
      <label for="title">Post Title</label>
      <input id="title" name="title" type="text" value="<%= post.title %>" />
    </div>

    <div class="form-group">
      <label for="content">Content</label>
      <input type="hidden" name="content" id="content" value="<%= post.content %>">
      <div id="editor-container" class="editor-well"></div>
    </div>

    <div class="editor-actions">
      <a href="/posts/<%= post.id %>" class="btn btn-secondary">Cancel</a>
      <button type="submit" class="btn btn-primary" style="padding: 14px 36px;">Save Changes</button>
    </div>
  </form>
</section>
