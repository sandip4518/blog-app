<article class="post-full animate-fade-in" style="max-width: 800px; margin: 0 auto; padding-bottom: 60px;">
  <header>
    <div style="margin-bottom: 20px;">
      <a href="/my-posts" class="btn btn-secondary" style="font-size: 0.78rem; padding: 8px 20px; min-height: 36px;">
        ← Back to Dashboard
      </a>
    </div>
    <span class="label-stamp" style="display: block; margin-bottom: 12px;">
      <span class="led led-green" style="width: 6px; height: 6px;"></span>
      Published Document
    </span>
    <h1 style="font-size: 3rem; margin-bottom: 20px; line-height: 1.1;"><%= post.title %></h1>
    <div class="post-meta">
      <span>📅 <%= new Date(post.createdAt).toLocaleDateString(undefined, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
      <span>•</span>
      <span>🕒 <%= new Date(post.createdAt).toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' }) %></span>
    </div>
  </header>

  <div class="content post-content-panel" style="margin-top: 8px;">
    <%- sanitizeHtml(post.content) %>
  </div>

  <div class="post-actions">
    <a href="/my-posts" class="btn btn-secondary">Back to Posts</a>
    <div style="display: flex; gap: 12px; flex-wrap: wrap;">
      <a class="btn btn-primary" href="/posts/<%= post.id %>/edit">Edit Post</a>
      <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" style="margin: 0;">
        <button class="btn btn-danger" type="submit" onclick="return confirm('Are you sure you want to delete this post? This action cannot be undone.')">Delete Post</button>
      </form>
    </div>
  </div>
</article>
