<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="A premium blogging platform with an industrial design. Create, manage, and share your stories." />
  <title><%= typeof title !== 'undefined' ? title + ' — BlogForge' : 'BlogForge' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
  <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
  <script src="/js/quill-setup.js" defer></script>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a class="brand" href="/">
        <!-- Industrial gear/bolt icon -->
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" stroke="#2d3436" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="brand-led"></span>
        BlogForge
      </a>
      <nav class="nav-menu">
        <a class="nav-link" href="/">Home</a>
        <% if (locals.user) { %>
          <a class="nav-link" href="/my-posts">My Posts</a>
          <a class="btn btn-primary" href="/posts/new" style="padding: 8px 20px; font-size: 0.78rem; min-height: 40px;">+ New Post</a>
          <form action="/logout" method="POST" style="display: inline; margin: 0;">
            <button type="submit" class="nav-link" style="background: none; border: none; cursor: pointer; font-family: var(--font-sans); font-size: inherit; padding: 10px 18px;">
              Logout
            </button>
          </form>
        <% } else { %>
          <a class="nav-link" href="/login">Login</a>
          <a class="btn btn-primary" href="/register" style="padding: 8px 20px; font-size: 0.78rem; min-height: 40px;">Get Started</a>
        <% } %>
      </nav>
    </div>
  </header>
  
  <% if (locals.user) { %>
    <div class="container" style="padding-top: 16px; padding-bottom: 8px;">
      <div class="user-badge">
        <span class="user-badge-led"></span>
        <span class="user-badge-label">Logged in as</span>
        <strong class="user-badge-name"><%= user.username %></strong>
      </div>
    </div>
  <% } %>

  <main class="container" style="padding-top: 16px; padding-bottom: 40px;">
    <%- body %>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>&copy; <%= new Date().getFullYear() %> BlogForge &middot; Precision-crafted with <span style="color: var(--accent);">♥</span> &middot; SYS OPERATIONAL</p>
    </div>
  </footer>
</body>
</html>
